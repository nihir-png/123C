<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (API 26+) — the real launcher icon on this app
  (minSdk 26). Both layers derive from the EXACT source artwork
  custom_app_icon.png:
    - background: solid #F7F7F7 (the icon's own background color)
    - foreground: @drawable/ic_launcher_foreground (custom_app_icon inset 10%)
  Because the background matches the icon's fill, the masked result reads as the
  original light icon with NO padding ring and no fallback to a generated icon.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
