<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground for the LAUNCHER icon.

  Android adaptive icons use a 108×108 dp canvas but only the inner 72×72 dp
  (66.67%) is guaranteed visible — the outer 18 dp on each side is reserved for
  the parallax/motion effect and is CROPPED by every launcher.

  Inset history:
    - 10% per side: artwork extended into the crop zone, so launcher masks cut
      off the sides/top/bottom and the icon looked zoomed/cropped.
    - 25% per side: safe from cropping, but left too much empty space so the
      icon looked too small on the home screen.

  Current inset = 20% per side. This keeps the whole artwork inside the safe
  zone (no mask cropping) while filling more of the icon area, so the launcher
  icon reads at proportions close to the original custom_app_icon.png — not
  cropped, not too small, and centered. The matching #F7F7F7 background layer
  fills the surrounding area seamlessly.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/custom_app_icon"
    android:insetLeft="20%"
    android:insetTop="20%"
    android:insetRight="20%"
    android:insetBottom="20%" />
