<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ splash screen icon: the EXACT same custom_app_icon.png, not
  redesigned or recolored.

  The system clips the splash icon to a circle (content must sit within the
  central ~66% to avoid clipping). Inset = 24% per side keeps the whole icon —
  including the red +/= pill that reaches the corners — comfortably inside that
  circle at the proportion Android uses for splash icons. The matching
  #F7F7F7 splash background (set in values-v31/themes.xml) fills the inset, so
  the icon reads as centered on a seamless light background with no ring.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/custom_app_icon"
    android:insetLeft="24%"
    android:insetTop="24%"
    android:insetRight="24%"
    android:insetBottom="24%" />
