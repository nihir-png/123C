<resources>
    <!--
      API 31+ (Android 12+) variant of the app theme. Identical to the base
      Theme.AICalculator (values/themes.xml) but adds the system splash screen,
      reusing the SAME custom icon (custom_app_icon.png via @drawable/splash_icon)
      on a background that matches the icon's own #F7F7F7 fill so the splash is
      seamless. Only splash-related attributes are added here; nothing else
      about the theme changes.
    -->
    <style name="Theme.AICalculator" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#F7F8FA</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Android 12+ splash screen -->
        <item name="android:windowSplashScreenBackground">#F7F7F7</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
    </style>
</resources>
