<?xml version="1.0" encoding="utf-8"?>
<!--
  Round adaptive launcher icon (API 26+). Identical layers to ic_launcher so the
  round mask shows the same custom_app_icon.png artwork (light #F7F7F7 background
  + foreground inset 10%), centered with no padding ring.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
